# ── FREE APIs (all have free tiers, no credit card required) ───────────────────

# 1. Groq  →  console.groq.com  →  "API Keys"  →  "Create Free Key"
#    Free: ~14,400 requests/day on llama-3.1-8b-instant
GROQ_API_KEY=gsk_...

# 2. Finnhub  →  finnhub.io  →  "Dashboard"  →  copy the key shown on screen
#    Free: 60 calls/minute, company & general market news
FINNHUB_API_KEY=your_finnhub_key_here

# 3. NewsAPI  →  newsapi.org  →  "Get API Key"  →  Developer plan (free)
#    Free: 100 requests/day, financial headlines
NEWSAPI_KEY=your_newsapi_key_here

# ── Pipeline settings (safe defaults, no need to change) ───────────────────────
PIPELINE_INTERVAL_SECONDS=60
MAX_ARTICLES_PER_SOURCE=50
SENTIMENT_BATCH_SIZE=16
E2E_DEADLINE_SECONDS=120
